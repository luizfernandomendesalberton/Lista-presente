# Configuracao para envio de notificacoes por e-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@example.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_USE_TLS=1

# E-mail que vai receber a notificacao quando um presente for reservado
NOTIFY_TO_EMAIL=seu_email@example.com, outro_email@example.com

# Opcional: remetente exibido no e-mail
FROM_EMAIL=seu_email@example.com

# Opcional: protege criacao/remocao de presentes na API
# Se definir, sera necessario informar o token no campo "Token de admin" da tela.
ADMIN_TOKEN=

# Administradores permitidos para login na tela /admin
ADMIN_USER_1_EMAIL=admin1@example.com
ADMIN_USER_1_PASSWORD=sua_senha_admin_1
ADMIN_USER_2_EMAIL=admin2@example.com
ADMIN_USER_2_PASSWORD=sua_senha_admin_2

# Chave de sessao do Flask (use um valor forte e privado em producao)
FLASK_SECRET_KEY=

# Opcional: caminho do arquivo JSON de dados quando usar disco persistente no Render
DATA_FILE_PATH=/var/data/presentes.json




